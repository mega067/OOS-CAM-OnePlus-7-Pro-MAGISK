<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:height="?userAssistiveFrameSize" android:width="?userAssistiveFrameSize">
        <shape android:shape="rectangle">
            <corners android:radius="?userAssistiveFrameBorderCornerRadius" />
            <stroke android:width="?userAssistiveFrameBorderStrokeWidth" android:color="@color/user_assistive_frame" />
        </shape>
    </item>
    <item android:gravity="center_vertical" android:height="?userAssistiveFrameSize" android:width="?userAssistiveFrameSize">
        <shape android:shape="line">
            <stroke android:width="?userAssistiveFrameInnerBorderStrokeWidth" android:color="@color/user_assistive_frame" />
        </shape>
    </item>
    <item android:gravity="center_horizontal" android:height="?userAssistiveFrameSize" android:width="?userAssistiveFrameSize">
        <rotate android:fromDegrees="90.0">
            <shape android:shape="line">
                <stroke android:width="?userAssistiveFrameInnerBorderStrokeWidth" android:color="@color/user_assistive_frame" />
            </shape>
        </rotate>
    </item>
</layer-list>